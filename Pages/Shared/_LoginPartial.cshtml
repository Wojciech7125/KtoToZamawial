@if (User.Identity.IsAuthenticated)
{
    <span class="me-2">Cześć, @User.Identity.Name!</span>
    <form method="post" asp-page="/Account/Logout" style="display:inline">
        <button type="submit" class="btn btn-secondary btn-sm">Wyloguj</button>
    </form>
}
else
{
    <a asp-page="/Account/Login" class="btn btn-primary btn-sm">Zaloguj się</a>
}
