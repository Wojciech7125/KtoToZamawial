@page
@model Magazyn.Pages.Stock.IndexModel
@{
    ViewData["Title"] = "Stany ";
}

<h1>Stany magazynowe</h1>

<p>
    <a asp-page="Operation" asp-route-type="IN" class="btn btn-success">Przyjecie</a>
    <a asp-page="Operation" asp-route-type="OUT" class="btn btn-warning">Wydanie</a>
</p>

<table class="table table-striped">
    <tr>
        <th>
            <a asp-page="Index" asp-route-sortBy="name" asp-route-desc="@(Model.SortBy == "name" && !Model.Desc)">
                Produkt @(Model.SortBy == "name" ? (Model.Desc ? "↓" : "↑") : "↕")
            </a>
        </th>
        <th>
            <a asp-page="Index" asp-route-sortBy="quantity" asp-route-desc="@(Model.SortBy == "quantity" && !Model.Desc)">
                Ilosc @(Model.SortBy == "quantity" ? (Model.Desc ? "↓" : "↑") : "↕")
            </a>
        </th>
        <th>
            <a asp-page="Index" asp-route-sortBy="min" asp-route-desc="@(Model.SortBy == "min" && !Model.Desc)">
                Min @(Model.SortBy == "min" ? (Model.Desc ? "↓" : "↑") : "↕")
            </a>
        </th>
        <th>Status</th>
    </tr>
    @foreach (var p in Model.Products)
    {
        var status = p.Quantity < p.MinQuantity ? "NISKI" :
                     p.Quantity < (int)(p.MinQuantity * 1.2) ? "BLISKO" : "OK";
        var klasa = status == "NISKI" ? "table-danger" : status == "BLISKO" ? "table-warning" : "";
        <tr class="@klasa">
            <td>@p.Name</td>
            <td>@p.Quantity</td>
            <td>@p.MinQuantity</td>
            <td>@status</td>
        </tr>
    }
</table>
