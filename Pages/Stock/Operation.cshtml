@page
@model Magazyn.Pages.Stock.OperationModel
@{
    var opType = ViewContext.HttpContext.Request.Query["type"].ToString();
    if (string.IsNullOrEmpty(opType)) opType = Model.Type ?? "IN";
    ViewData["Title"] = opType == "IN" ? "Przyjecie" : "Wydanie";
}

<h1>@ViewData["Title"]</h1>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

<form method="post">
    <input type="hidden" name="Type" value="@opType" />

    <p>
        <label>Produkt:</label>
        <select asp-for="ProductId" class="form-control">
            <option value="">--</option>
            @foreach (var p in Model.Products)
            {
                <option value="@p.Id">@p.Name (@p.Quantity szt.)</option>
            }
        </select>
    </p>

    <p>
        <label>Ilosc:</label>
        <input asp-for="Quantity" type="number" min="1" class="form-control" />
    </p>

    <button type="submit" class="btn btn-primary">Zatwierdz</button>
    <a href="/Stock" class="btn btn-secondary">Anuluj</a>
</form>
