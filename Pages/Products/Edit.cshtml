@page "{id:int}"
@model Magazyn.Pages.Products.EditModel
@{
    ViewData["Title"] = "Edycja produktu";
}

<h1>Edycja produktu</h1>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Product.Id" />

    <p>
        <label>Nazwa:</label>
        <input asp-for="Product.Name" class="form-control" />
        <span asp-validation-for="Product.Name" class="text-danger"></span>
    </p>

    <p>
        <label>SKU:</label>
        <input asp-for="Product.Sku" class="form-control" />
        <span asp-validation-for="Product.Sku" class="text-danger"></span>
    </p>

    <p>
        <label>Kategoria:</label>
        <select asp-for="Product.CategoryId" class="form-control">
            <option value="">--</option>
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </p>

    <p>
        <label>Ilosc:</label>
        <input asp-for="Product.Quantity" type="number" class="form-control" />
    </p>

    <p>
        <label>Min:</label>
        <input asp-for="Product.MinQuantity" type="number" class="form-control" />
    </p>

    <p>
        <label>Cena:</label>
        <input asp-for="Product.Price" type="number" step="0.01" class="form-control" />
    </p>

    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a href="/Products" class="btn btn-secondary">Anuluj</a>
</form>
