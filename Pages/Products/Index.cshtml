@page
@model Magazyn.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Produkty";
}

<h1>Produkty</h1>

<form method="get">
    <input type="text" name="search" value="@Model.Search" placeholder="Szukaj..." />
    <button type="submit" class="btn btn-primary">Szukaj</button>
</form>
<br />

<a asp-page="Create" class="btn btn-success">Dodaj produkt</a>
<br /><br />

<table class="table">
    <tr>
        <th>Nazwa</th>
        <th>SKU</th>
        <th>Kategoria</th>
        <th>Ilosc</th>
        <th>Cena</th>
        <th></th>
    </tr>
    @foreach (var p in Model.Products)
    {
        var cat = Model.Categories.FirstOrDefault(c => c.Id == p.CategoryId);
        var klasa = p.Quantity < p.MinQuantity ? "table-danger" : "";
        <tr class="@klasa">
            <td>@p.Name</td>
            <td>@p.Sku</td>
            <td>@(cat?.Name ?? "-")</td>
            <td>@p.Quantity</td>
            <td>@p.Price</td>
            <td>
                <a asp-page="Edit" asp-route-id="@p.Id">Edytuj</a>
                |
                <a asp-page="Delete" asp-route-id="@p.Id">Usun</a>
            </td>
        </tr>
    }
</table>
