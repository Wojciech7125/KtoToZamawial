@page
@model Magazyn.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Produkty ";
}

<h1>Produkty</h1>

<form method="get">
    <input type="text" name="search" value="@Model.Search" placeholder="Szukaj..." />
    <button type="submit" class="btn btn-primary">Szukaj</button>
</form>
<br />

<a asp-page="Create" class="btn btn-success">Dodaj produkt</a>
<br /><br />

<table class="table">
    <tr>
        <th>
            <a asp-page="Index" asp-route-search="@Model.Search" asp-route-sortBy="name" asp-route-desc="@(Model.SortBy == "name" && !Model.Desc)">
                Nazwa @(Model.SortBy == "name" ? (Model.Desc ? "↓" : "↑") : "↕")
            </a>
        </th>
        <th>
            <a asp-page="Index" asp-route-search="@Model.Search" asp-route-sortBy="category" asp-route-desc="@(Model.SortBy == "category" && !Model.Desc)">
                Kategoria @(Model.SortBy == "category" ? (Model.Desc ? "↓" : "↑") : "↕")
            </a>
        </th>
        <th>
            <a asp-page="Index" asp-route-search="@Model.Search" asp-route-sortBy="quantity" asp-route-desc="@(Model.SortBy == "quantity" && !Model.Desc)">
                Ilosc @(Model.SortBy == "quantity" ? (Model.Desc ? "↓" : "↑") : "↕")
            </a>
        </th>
        <th>
            <a asp-page="Index" asp-route-search="@Model.Search" asp-route-sortBy="price" asp-route-desc="@(Model.SortBy == "price" && !Model.Desc)">
                Cena @(Model.SortBy == "price" ? (Model.Desc ? "↓" : "↑") : "↕")
            </a>
        </th>
        <th></th>
    </tr>
    @foreach (var p in Model.Products)
    {
        var cat = Model.Categories.FirstOrDefault(c => c.Id == p.CategoryId);
        var klasa = p.Quantity < p.MinQuantity ? "table-danger" : "";
        <tr class="@klasa">
            <td>@p.Name</td>
            <td>@(cat?.Name ?? "-")</td>
            <td>@p.Quantity</td>
            <td>@p.Price</td>
            <td>
                <a asp-page="Edit" asp-route-id="@p.Id">Edytuj</a>
                |
                <a asp-page="Delete" asp-route-id="@p.Id">Usun</a>
            </td>
        </tr>
    }
</table>
