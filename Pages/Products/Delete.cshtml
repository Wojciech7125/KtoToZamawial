@page "{id:int}"
@model Magazyn.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Usuwanie produktu";
}

<h1>Usuwanie produktu</h1>

<p>Na pewno usunac ten produkt?</p>

<p>
    <b>@Model.Product.Name</b>
</p>

<form method="post">
    <input type="hidden" name="id" value="@Model.Product.Id" />
    <button type="submit" class="btn btn-danger">Usun</button>
    <a href="/Products" class="btn btn-secondary">Anuluj</a>
</form>
